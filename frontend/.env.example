# Supabase（公開キー。VITE_ プレフィックスでビルド時にバンドルされる）
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# バックエンド API URL
# 開発時: http://localhost:8000
# 本番時: https://your-app.railway.app
VITE_API_BASE_URL=http://localhost:8000

# 注意: 機密情報（SERVICE_ROLE_KEY, ANTHROPIC_API_KEY 等）は
# VITE_ プレフィックスで設定しないこと（NFR-101）

# note.com 自動投稿（npm run post:note で使用）
NOTE_EMAIL=
NOTE_PASSWORD=
# NOTE_PUBLISH=true  # コメントを外すと下書きではなく公開する
