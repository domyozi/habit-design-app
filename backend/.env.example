# Supabase 設定
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Claude API（サーバー側のみ。クライアントには絶対に露出しないこと: NFR-101）
ANTHROPIC_API_KEY=

# Resend メール通知
RESEND_API_KEY=

# CORS 許可オリジン（カンマ区切りで複数指定可）
# 本番例: FRONTEND_URL=https://your-app.vercel.app
# プレビュー含む例: FRONTEND_URL=https://your-app.vercel.app,https://your-app-preview.vercel.app
FRONTEND_URL=http://localhost:5173,http://localhost:5174

# Journal投稿後の旧バックグラウンドAI抽出
# v3はFlowのCoach Proposalに一本化するため通常はfalse。
JOURNAL_BACKGROUND_MEMORY_EXTRACTION_ENABLED=false
JOURNAL_BACKGROUND_SUGGESTION_EXTRACTION_ENABLED=false

# Google OAuth (Calendar 連携)
# config.py の default は localhost。本番デプロイ時は **必ず本番 URL に上書き** する。
# Google Cloud Console > 認証情報 > OAuth 2.0 クライアント の「承認済みのリダイレクト URI」にも
# 同じ URL を登録する必要がある。
# 例:
#   GOOGLE_REDIRECT_URI=https://api.your-domain.com/api/integrations/google/oauth/callback
#   GOOGLE_OAUTH_FE_RETURN_URL=https://your-app.vercel.app/calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/integrations/google/oauth/callback
GOOGLE_OAUTH_FE_RETURN_URL=http://localhost:5175/calendar

# Google OAuth トークンの対称暗号化キー（Fernet, 32B base64）
# 生成: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 空のままだと token は平文保管になる（dev では許容、本番デプロイ前に必ず設定）。
OAUTH_TOKEN_ENC_KEY=
