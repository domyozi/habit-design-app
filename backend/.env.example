# Supabase 設定
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Claude API（サーバー側のみ。クライアントには絶対に露出しないこと: NFR-101）
ANTHROPIC_API_KEY=

# Resend メール通知
RESEND_API_KEY=

# CORS 許可オリジン（カンマ区切りで複数指定可）
# 本番例: FRONTEND_URL=https://your-app.vercel.app
# プレビュー含む例: FRONTEND_URL=https://your-app.vercel.app,https://your-app-preview.vercel.app
FRONTEND_URL=http://localhost:5173,http://localhost:5174
